# ============================================================
# DayTraderPorn.com — Environment Variables
# Copy to .env.local and fill in your values
# ============================================================

# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# NextAuth (required)
NEXTAUTH_URL=https://yourdomain.com
NEXTAUTH_SECRET=your-nextauth-secret-generate-with-openssl-rand-base64-32

# Demo mode (optional — set to true to auto-inject demo session)
NEXT_PUBLIC_DEMO_MODE=false

# Agora.io — live streaming (optional, set to enable)
NEXT_PUBLIC_AGORA_APP_ID=your-agora-app-id
AGORA_APP_CERTIFICATE=your-agora-app-certificate

# Whereby.com — video calls (optional, set to enable)
WHEREBY_API_KEY=your-whereby-api-key

# Market data
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-key

# Solana
NEXT_PUBLIC_SOLANA_NETWORK=mainnet-beta

# TipLink (optional)
TIPLINK_API_KEY=your-tiplink-api-key

# Platform affiliate tracking (optional)
SEXTPANTHER_AFFILIATE_ID=your-id
FANVUE_AFFILIATE_ID=your-id
LOYALFANS_AFFILIATE_ID=your-id
MANYVIDS_AFFILIATE_ID=your-id
NITEFLIRT_AFFILIATE_ID=your-id
