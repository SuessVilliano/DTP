# ==========================================
# DTP - Day Trader Porn
# Environment Variables
# ==========================================

# --- App ---
NEXT_PUBLIC_APP_URL=https://daytraderporn.com
NEXT_PUBLIC_APP_NAME="Day Trader Porn"
NODE_ENV=production

# --- NextAuth ---
NEXTAUTH_URL=https://daytraderporn.com
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# --- Google OAuth ---
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# --- Database (Postgres via Supabase) ---
DATABASE_URL=postgresql://user:password@host:5432/dtp

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Market Data ---
NEXT_PUBLIC_BINANCE_WS_URL=wss://stream.binance.com:9443/ws
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-key

# --- Payments ---
NOWPAYMENTS_API_KEY=your-nowpayments-api-key
NOWPAYMENTS_IPN_SECRET=your-ipn-secret
NEXT_PUBLIC_NOWPAYMENTS_PUBLIC_KEY=your-public-key
TIPLINK_API_KEY=your-tiplink-api-key
NEXT_PUBLIC_TIPLINK_PUBLIC_KEY=your-tiplink-public-key
COINBASE_COMMERCE_API_KEY=your-coinbase-commerce-key
X402_FACILITATOR_URL=https://x402.org/facilitator
NEXT_PUBLIC_USDC_PRICE_BULL=9.99
NEXT_PUBLIC_USDC_PRICE_WHALE=49.99

# --- Solana ---
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
NEXT_PUBLIC_DTP_TOKEN_MINT=PLACEHOLDER_DTP_TOKEN_MINT_ADDRESS
NEXT_PUBLIC_DTP_TOKEN_DECIMALS=9
NEXT_PUBLIC_BULL_TIER_AMOUNT=1000
NEXT_PUBLIC_WHALE_TIER_AMOUNT=10000

# --- ExoClick ---
NEXT_PUBLIC_EXOCLICK_PUBLISHER_ID=PLACEHOLDER_EXOCLICK_ID
NEXT_PUBLIC_EXOCLICK_ZONE_300x250=PLACEHOLDER_ZONE_300x250
NEXT_PUBLIC_EXOCLICK_ZONE_728x90=PLACEHOLDER_ZONE_728x90
NEXT_PUBLIC_EXOCLICK_ZONE_NATIVE=PLACEHOLDER_ZONE_NATIVE

# --- Admin ---
ADMIN_SECRET_KEY=generate-strong-admin-secret
ADMIN_EMAIL=admin@daytraderporn.com

# --- Content / Storage ---
S3_ENDPOINT=https://nyc3.digitaloceanspaces.com
S3_BUCKET=dtp-content
S3_ACCESS_KEY=your-spaces-access-key
S3_SECRET_KEY=your-spaces-secret-key
S3_REGION=nyc3
NEXT_PUBLIC_CDN_URL=https://cdn.daytraderporn.com

# --- DMCA & Legal ---
DMCA_AGENT_EMAIL=dmca@daytraderporn.com
COMPLIANCE_CUSTODIAN_NAME="Legal Custodian Name"
COMPLIANCE_CUSTODIAN_ADDRESS="Address on file"

# --- Rate Limiting ---
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- CreatorCommand.club ---
CC_WEBHOOK_SECRET=generate-with-openssl-rand-hex-32
CC_API_URL=https://app.creatorcommand.club
CC_API_KEY=your-cc-api-key

# --- SextPanther Affiliate ---
NEXT_PUBLIC_SEXTPANTHER_AFFILIATE_ID=your-affiliate-id

# --- x402 Receiving Address ---
X402_RECEIVING_ADDRESS=0xYOUR_RECEIVING_ADDRESS_ON_BASE
